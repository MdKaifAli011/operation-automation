# Copy to `.env` or `.env.local` at the repo root. Next.js loads `.env` then `.env.local`
# (local overrides). Do not commit real secrets — this file is the template only.

# --- Required ---
MONGODB_URI=mongodb://127.0.0.1:27017/operation-automation

# --- Public URL (absolute links in emails: Meet, feedback, etc.) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# APP_BASE_URL=http://localhost:3000

# --- Mail (preferred names; sendMail also accepts SMTP_* / MAIL_HOST aliases) ---
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=Your Institute
# MAIL_REPLY_TO=
# MAIL_SMTP_DEBUG=0

# --- Enrollment / demos (optional) ---
ENROLLMENT_TEAM_BCC=
# ENROLLMENT_FORM_URL=
# MEET_HOLD_DURATION_MINUTES=300
# TEACHER_DEMO_BLOCK_MINUTES=120
# DEMO_AUTO_COMPLETE_AFTER_MINUTES=300
# DEMO_TEACHER_FEEDBACK_AFTER_MINUTES=45
# DEMO_AUTO_SEND_INVITE=true

# --- Daily FX (CurrencyAPI) — one external request per IST calendar day ---
# Key: https://app.currencyapi.com/dashboard
CURRENCYAPI_KEY=
# Random long string; your scheduler or manual curl must send: Authorization: Bearer <same value>
CRON_SECRET=

# --- Seed script (`npm run seed`) only; never leave enabled in production ---
# FORCE_SEED=1

# --- Authentication (Cloudflare Turnstile) ---
# Enable/disable CAPTCHA verification (set to "0" to disable)
TURNSTILE_ENABLED=0
NEXT_PUBLIC_TURNSTILE_ENABLED=0
# Cloudflare Turnstile keys (get from https://dash.cloudflare.com/ -> Turnstile)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Initial Admin Setup ---
# Admin user credentials (run npm run seed-admin to create)
ADMIN_EMAIL=admin@testprepkart.com
ADMIN_PASSWORD=your-secure-password-here
ADMIN_NAME=Administrator
# Set to 1 to force update existing admin password
# FORCE_UPDATE_ADMIN=1
